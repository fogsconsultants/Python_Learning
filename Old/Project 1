"""Understand What You’re Building - You’re building a system that:

Takes student data
Calculates results
Prints results
Shows analytics

We’ll build it in 7 steps:

Basic input
Store data
Recursion (sum)
Calculations
Grade logic
Display
Analytics + sorting
"""


num_students = int(input("Enter number of students: "))
for i in range(1, num_students + 1):
    print(f"Enter details for Student {i}")
    
    name = input("Name: ")
    roll = input("Roll No: ")
    
    #num_subjects = int(input("Enter number of subjects: "))

    marks_subject = []
    for j in range(1, 4):
        mark=int(input(f"Marks for Subject {j}: "))
        marks_subject+=[mark]
        
    print(f"Student: {name}, Roll No: {roll}, Marks: {marks_subject}")
student = {
        "name": name,
        "roll": roll,
        "marks": marks_subject
    }
students = []
students+=(student)
def calculate_total(marks, index=0):
    if index == len(marks):
        return 0
    return marks[index] + calculate_total(marks, index + 1)

def calculate_average(total, num_subjects):
    return total / num_subjects    
def get_grade(avg):
    if avg >= 90:
        return "A"
    elif avg >= 75:
        return "B"
    elif avg >= 50:
        return "C"
    else:
        return "Fail"
    
for student in students:
    total = calculate_total(student["marks"])
    avg = calculate_average(total, len(student["marks"]))
    grade = get_grade(avg)
    
    student["total"] = total
    student["average"] = avg
    student["grade"] = grade

print("\n******** STUDENT RESULTS ********")

for student in students:
    print(f"\nName: {student['name']}")
    print(f"Roll No: {student['roll']}")
    print(f"Total: {student['total']}")
    print(f"Average: {round(student['average'], 2)}")
    print(f"Grade: {student['grade']}")
    print("-----------------------------")

topper = max(students, key=lambda x: x["average"])

class_avg = sum(s["average"] for s in students) / len(students)

failed = [s for s in students if s["grade"] == "Fail"]

print("\n🎯 CLASS ANALYTICS")

print(f"Topper: {topper['name']} ({round(topper['average'],2)})")
print(f"Class Average: {round(class_avg,2)}")

print("\nFailed Students:")
if failed:
    for s in failed:
        print(s["name"])
else:
    print("None 🎉")

print("\n*****")
print("RESULT")
print("*****")
