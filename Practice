# Write a python program to find out the number entered by the user is prime or not.

number=int(input("Enter a number : "))
is_prime=True
if number>1:
    for k in range(2,int(number*0.5)+1):
        if number%k==0:
            is_prime=False
            print(f"{number} is not a prime number")
            break
        else:            
            print(f"{number} is a prime number")
    if is_prime:
        print(f"{number} is a prime number")        

    else:
        print(f"{number} is not a prime number")